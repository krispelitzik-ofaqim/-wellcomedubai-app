{
  "expo": {
    "name": "WellCome Dubai",
    "slug": "wellcomedubai-app",
    "scheme": "wellcomedubai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF6EC"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.wellcomedubai.app",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "אנחנו משתמשים במיקום שלך כדי להראות מסעדות, אטרקציות ומלונות קרובים בדובאי."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FDF6EC"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.wellcomedubai.app"
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "אנחנו משתמשים במיקום שלך כדי להראות מסעדות, אטרקציות ומלונות קרובים בדובאי."
        }
      ],
      "@react-native-community/datetimepicker"
    ],
    "extra": {
      "router": {},
      "eas": {
        "projectId": "49b2db9e-1967-4831-b6e0-5a0eb5d03423"
      }
    },
    "owner": "krispel",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/49b2db9e-1967-4831-b6e0-5a0eb5d03423"
    }
  }
}
